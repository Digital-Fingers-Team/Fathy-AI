{
  "$schema": "https://schema.railpack.com",

  "provider": "python",

  "packages": {
    "python": "3.11"
  },

  "buildAptPackages": ["curl", "git"],

  "steps": {
    "install": {
      "commands": [
        "pip install -r backend/requirements.txt"
      ]
    }
  },

  "deploy": {
    "startCommand": "python -m uvicorn backend/app.main:app --host 0.0.0.0 --port 8000"
  }
}